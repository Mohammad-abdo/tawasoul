// ==============================
// VB-MAPP ENUMS (مفاتيح التقييم)
// ==============================

enum VbMappSkillLevel {
  LEVEL_1 // 0-18 شهر
  LEVEL_2 // 18-30 شهر
  LEVEL_3 // 30-48 شهر
}

enum VbMappAssessmentMethod {
  DIRECT       // فحص مباشر (ف)
  OBSERVATION  // مراقبة (م)
  BOTH         // الاثنين (ف/م)
  TIMED        // مدة المراقبة (م.م)
}

/// Milestones, EESA echoic items: 0 / 0.5 / 1 scale (plus not tested).
enum VbMappScoreValue {
  ACHIEVED      // ✓ (يساوي 1)
  PARTIAL       // / (يساوي 0.5)
  NOT_ACHIEVED  // ✗ (يساوي 0)
  NOT_TESTED    // لم يتم اختباره
}

/// Transitions assessment: strict 1–5 scale only (not the milestone 0/0.5/1 scale).
enum VbMappTransitionScoreValue {
  ONE
  TWO
  THREE
  FOUR
  FIVE
}

enum VbMappSessionNumber {
  FIRST
  SECOND
  THIRD
  FOURTH
}

enum VbMappBarrierScoresEnum {
  ZERO
  ONE
  TWO
  THREE
  FOUR
}

enum VbMappIEPStatus {
  ACTIVE
  ACHIEVED
  DISCONTINUED
}

// ==============================
// VB-MAPP STATIC DATA (البيانات الثابتة)
// ==============================

model VbMappSkillArea {
  id         Int               @id @default(autoincrement())
  code       String            @unique // MAND, TACT, LISTENER, etc.
  nameAr     String
  nameEn     String
  level      VbMappSkillLevel
  order      Int
  milestones VbMappMilestone[]

  @@map("vb_mapp_skill_areas")
}

model VbMappMilestone {
  id               Int                    @id @default(autoincrement())
  skillAreaId      Int
  skillArea        VbMappSkillArea        @relation(fields: [skillAreaId], references: [id])
  milestoneNumber  Int                    // 1-15
  level            VbMappSkillLevel
  descriptionAr    String                 @db.Text
  assessmentMethod VbMappAssessmentMethod
  timedDuration    Int?                   // بالثواني لو كان م.م
  order            Int
  taskSteps        VbMappTaskStep[]
  scores           VbMappMilestoneScore[]
  iepGoals         VbMappIEPGoal[]

  @@unique([skillAreaId, milestoneNumber, level])
  @@map("vb_mapp_milestones")
}

model VbMappTaskStep {
  id               Int                    @id @default(autoincrement())
  milestoneId      Int
  milestone        VbMappMilestone        @relation(fields: [milestoneId], references: [id])
  stepCode         String                 // "1-أ", "1-ب"
  descriptionAr    String                 @db.Text
  assessmentMethod VbMappAssessmentMethod
  timedDuration    Int?
  order            Int
  scores           VbMappTaskStepScore[]

  @@unique([milestoneId, stepCode])
  @@map("vb_mapp_task_steps")
}

model VbMappBarrier {
  id     Int                  @id @default(autoincrement())
  nameAr String
  nameEn String
  order  Int
  scores VbMappBarrierScores[]

  @@map("vb_mapp_barriers")
}

model VbMappTransitionCriteria {
  id            Int                     @id @default(autoincrement())
  nameAr        String
  descriptionAr String?                 @db.Text
  order         Int
  scores        VbMappTransitionScores[]

  @@map("vb_mapp_transition_criteria")
}

// ==============================
// VB-MAPP EESA — Early Echoic Skills Assessment (static + per-session scores)
// ==============================

model VbMappEesaGroup {
  id     Int             @id @default(autoincrement())
  code   String?         @unique
  nameAr String
  nameEn String
  order  Int
  items  VbMappEesaItem[]

  @@map("vb_mapp_eesa_groups")
}

model VbMappEesaItem {
  id            Int               @id @default(autoincrement())
  groupId       Int
  group         VbMappEesaGroup   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  /// Stimulus word or syllable target (VB-MAPP echoic list).
  word          String
  syllableCount Int
  order         Int
  scores        VbMappEesaScore[]

  @@index([groupId])
  @@map("vb_mapp_eesa_items")
}

// ==============================
// VB-MAPP DYNAMIC DATA (الجلسات والتقييمات)
// ==============================

model VbMappSession {
  id               String                  @id @default(uuid())
  childId          String
  child            Child                   @relation(fields: [childId], references: [id], onDelete: Cascade)
  evaluatorId      String
  evaluator        Doctor                  @relation(fields: [evaluatorId], references: [id])
  bookingId        String?                 @unique
  booking          Booking?                @relation(fields: [bookingId], references: [id])
  sessionNumber    VbMappSessionNumber
  assessmentDate   DateTime
  colorCode        String?
  notes            String?                 @db.Text
  totalScore       Float?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  milestoneScores  VbMappMilestoneScore[]
  taskStepScores   VbMappTaskStepScore[]
  barrierScores    VbMappBarrierScores[]
  transitionScores VbMappTransitionScores[]
  eesaScores       VbMappEesaScore[]
  iepGoals         VbMappIEPGoal[]


  @@unique([childId, sessionNumber])
  @@index([childId])
  @@index([evaluatorId])
  @@map("vb_mapp_sessions")
}

model VbMappMilestoneScore {
  id          String           @id @default(uuid())
  sessionId   String
  session     VbMappSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  milestoneId Int
  milestone   VbMappMilestone  @relation(fields: [milestoneId], references: [id])
  score       VbMappScoreValue
  notes       String?          @db.Text
  scoredAt    DateTime         @default(now())

  @@unique([sessionId, milestoneId])
  @@index([milestoneId])
  @@map("vb_mapp_milestone_scores")
}

/// Task analysis steps: checklist only (achieved / not achieved + optional achievement date).
model VbMappTaskStepScore {
  id          String         @id @default(uuid())
  sessionId   String
  session     VbMappSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  stepId      Int
  step        VbMappTaskStep  @relation(fields: [stepId], references: [id])
  isAchieved  Boolean        @default(false)
  achievedAt  DateTime?
  notes       String?        @db.Text
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([sessionId, stepId])
  @@index([stepId])
  @@map("vb_mapp_task_step_scores")
}

model VbMappBarrierScores {
  id        String             @id @default(uuid())
  sessionId String
  session   VbMappSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  barrierId Int
  barrier   VbMappBarrier      @relation(fields: [barrierId], references: [id])
  score     VbMappBarrierScoresEnum
  notes     String?            @db.Text
  scoredAt  DateTime           @default(now())

  @@unique([sessionId, barrierId])
  @@index([barrierId])
  @@map("vb_mapp_barrier_scores")
}

model VbMappTransitionScores {
  id         String                    @id @default(uuid())
  sessionId  String
  session    VbMappSession             @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  criteriaId Int
  criteria   VbMappTransitionCriteria  @relation(fields: [criteriaId], references: [id])
  score      VbMappTransitionScoreValue
  notes      String?                   @db.Text
  scoredAt   DateTime                  @default(now())

  @@unique([sessionId, criteriaId])
  @@index([criteriaId])
  @@map("vb_mapp_transition_scores")
}

model VbMappIEPGoal {
  id              String           @id @default(uuid())
  childId         String
  child           Child            @relation(fields: [childId], references: [id], onDelete: Cascade)
  sessionId       String
  session         VbMappSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  milestoneId     Int?
  milestone       VbMappMilestone? @relation(fields: [milestoneId], references: [id])
  goalDescription String           @db.Text
  targetDate      DateTime?
  status          VbMappIEPStatus  @default(ACTIVE)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([childId])
  @@index([sessionId])
  @@map("vb_mapp_iep_goals")
}

/// Per-session echoic (EESA) scores: standard 0 / 0.5 / 1 scale via VbMappScoreValue.
model VbMappEesaScore {
  id        String           @id @default(uuid())
  sessionId String
  session   VbMappSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  itemId    Int
  item      VbMappEesaItem   @relation(fields: [itemId], references: [id])
  score     VbMappScoreValue
  notes     String?          @db.Text
  scoredAt  DateTime         @default(now())

  @@unique([sessionId, itemId])
  @@index([itemId])
  @@map("vb_mapp_eesa_scores")
}
