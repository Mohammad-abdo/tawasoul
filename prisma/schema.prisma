generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String          @id @default(uuid())
  fullName                String?
  username               String?         @unique
  email                  String?         @unique
  phone                  String?         @unique
  password               String?
  relationType            RelationType?
  language               String          @default("ar")
  allowPrivateMsg        Boolean         @default(true)
  isAnonymous           Boolean         @default(false)
  avatar                 String?
  isActive               Boolean         @default(true)
  isApproved             Boolean         @default(true)
  isPhoneVerified        Boolean         @default(false)
  isEmailVerified        Boolean         @default(false)
  emailVerificationToken String?        @unique
  emailVerificationExpiry DateTime?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  addresses              Address[]
  bookings              Booking[]
  cartItems              CartItem[]
  children               Child[]
  notifications          Notification[]
  orders                Order[]
  otpCodes               OtpCode[]
  productReviews        ProductReview[]
  supportReplies         SupportReply[]
  supportTickets        SupportTicket[]
  coupons                UserCoupon[]
  userPackages          UserPackage[]
  conversations          Conversation[]
  refreshTokens          RefreshToken[]
  articleComments      ArticleComment[]

  @@map("users")
}

model Article {
  id            String   @id @default(uuid())
  title         String
  content       String   @db.Text
  excerpt       String?  @db.Text
  authorId      String
  views         Int      @default(0)
  likes         Int      @default(0)
  comments      Int      @default(0)
  isRecommended Boolean  @default(false)
  isFeatured    Boolean  @default(false)
  featuredOrder Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  author        Doctor   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  articleComments ArticleComment[]

  @@index([authorId], map: "articles_authorId_fkey")
  @@map("articles")
}

model ArticleComment {
  id        String   @id @default(uuid())
  articleId String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([articleId])
  @@index([userId])
  @@map("article_comments")
}

model Doctor {
  id                String            @id @default(uuid())
  name              String
  email             String            @unique
  phone             String
  password          String
  hourlyRate        Decimal           @default(0) @db.Decimal(10, 2)
  bio               String?           @db.Text
  avatar            String?
  rating            Float             @default(0)
  totalSessions     Int               @default(0)
  totalRatings      Int               @default(0)
  isVerified        Boolean           @default(false)
  isActive          Boolean           @default(true)
  isApproved        Boolean           @default(false)
  approvalNotes     String?           @db.Text
  isFeatured        Boolean           @default(false)
  featuredOrder     Int?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  articles          Article[]
  availability      Availability[]
  bookings          Booking[]
  certificates      Certificate[]
  specialties       DoctorSpecialty[]
  education         Education[]
  experiences       Experience[]
  helpAssessments   HelpAssessment[]
  payments          Payment[]
  supportReplies    SupportReply[]
  supportTickets    SupportTicket[]
  wallet            DoctorWallet?
  walletRequests    WithdrawalRequest[]
  withdrawals       Withdrawal[]
  conversations     Conversation[]
  vbMappEvaluations VbMappSession[]
  refreshTokens    RefreshToken[]
  addresses        Address[]

  @@map("doctors")
}

model DoctorSpecialty {
  id        String   @id @default(uuid())
  doctorId  String
  specialty String
  createdAt DateTime @default(now())
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId], map: "doctor_specialties_doctorId_fkey")
  @@map("doctor_specialties")
}

model Experience {
  id         String    @id @default(uuid())
  doctorId   String
  title      String
  workplace  String
  startDate  DateTime
  endDate    DateTime?
  proofFile  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  doctor     Doctor    @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId], map: "experiences_doctorId_fkey")
  @@map("experiences")
}

model Certificate {
  id              String    @id @default(uuid())
  doctorId        String
  title           String
  issuer          String
  startDate       DateTime
  endDate         DateTime?
  certificateLink String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  doctor          Doctor    @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId], map: "certificates_doctorId_fkey")
  @@map("certificates")
}

model Education {
  id          String    @id @default(uuid())
  doctorId    String
  degree      String
  institution String
  startDate   DateTime
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  doctor      Doctor    @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId], map: "education_doctorId_fkey")
  @@map("education")
}

model Availability {
  id        String   @id @default(uuid())
  doctorId  String
  dayOfWeek Int
  timeSlots Json
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, dayOfWeek])
  @@map("availability")
}

model Child {
  id                String                  @id @default(uuid())
  userId            String
  name              String
  gender            Gender?                 @default(MALE)
  age               Int?
  status            ChildStatus?
  ageGroup          ChildAgeGroup?
  behavioralNotes   String?                 @db.Text
  caseDescription   String?                 @db.Text
  caseHistory       String?                 @db.Text
  profileImage      String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  assessmentResults AssessmentResult[]
  activityProgress  ChildActivityProgress[]
  bookings          Booking[]
  helpAssessments   HelpAssessment[]
  user              User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  vbMappSessions    VbMappSession[]
  vbMappIepGoals    VbMappIEPGoal[]

  @@index([userId], map: "children_userId_fkey")
  @@map("children")
}

model Booking {
  id                 String          @id @default(uuid())
  userId             String
  doctorId           String
  childId            String?
  category           SessionCategory @default(INDIVIDUAL)
  sessionType SessionType?
  duration           Int
  status             BookingStatus   @default(PENDING)
  scheduledYear      Int?
  scheduledMonth     Int?
  scheduledDay       Int?
  scheduledTime      String?
  notes              String?         @db.Text
  completedAt        DateTime?
  cancelledAt        DateTime?
  cancellationReason String?         @db.Text
  rating             Int?
  review             String?         @db.Text
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  videoLink          String?
  child              Child?          @relation(fields: [childId], references: [id])
  doctor             Doctor          @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  user               User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  vbMappSession      VbMappSession?

  @@index([childId], map: "bookings_childId_fkey")
  @@index([doctorId], map: "bookings_doctorId_fkey")
  @@index([userId], map: "bookings_userId_fkey")
  @@map("bookings")
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  senderRole     SenderRole

  content        String?      @db.Text
  messageType    MessageType  @default(TEXT)
  imageUrl       String?
  videoUrl       String?
  fileUrl        String?
  fileName       String?
  voiceUrl       String?
  voiceDuration  Int?
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("messages")
}

model Conversation {
  id        String   @id @default(uuid())
  userId    String
  doctorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@unique([userId, doctorId])
  @@index([userId])
  @@index([doctorId])
  @@map("conversations")
}

model Payment {
  id            String        @id @default(uuid())
  packageId     String
  doctorId      String
  amount        Float
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  transactionId String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  doctor        Doctor        @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  package       Package       @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([doctorId], map: "payments_doctorId_fkey")
  @@index([packageId], map: "payments_packageId_fkey")
  @@map("payments")
}

model Withdrawal {
  id             String           @id @default(uuid())
  doctorId       String
  amount         Float
  method         WithdrawalMethod
  accountDetails String           @db.Text
  status         WithdrawalStatus @default(PENDING)
  processedAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  doctor         Doctor           @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId], map: "withdrawals_doctorId_fkey")
  @@map("withdrawals")
}

model DoctorWallet {
  id            String              @id @default(uuid())
  doctorId      String              @unique
  balance       Decimal             @default(0) @db.Decimal(10, 2)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  doctor        Doctor              @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  transactions  WalletTransaction[]
  withdrawals   WithdrawalRequest[]

  @@index([doctorId], map: "doctor_wallets_doctorId_fkey")
  @@map("doctor_wallets")
}

model WalletTransaction {
  id          String                @id @default(uuid())
  walletId     String
  type        WalletTransactionType
  amount      Decimal               @db.Decimal(10, 2)
  description String?               @db.Text
  createdAt   DateTime              @default(now())
  wallet      DoctorWallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId], map: "wallet_transactions_walletId_fkey")
  @@map("wallet_transactions")
}

model WithdrawalRequest {
  id          String                   @id @default(uuid())
  walletId     String
  doctorId     String
  amount      Decimal                  @db.Decimal(10, 2)
  status      WithdrawalRequestStatus  @default(PENDING)
  createdAt   DateTime                 @default(now())
  resolvedAt  DateTime?
  wallet      DoctorWallet             @relation(fields: [walletId], references: [id], onDelete: Cascade)
  doctor      Doctor                   @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([walletId], map: "withdrawal_requests_walletId_fkey")
  @@index([doctorId], map: "withdrawal_requests_doctorId_fkey")
  @@map("withdrawal_requests")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String           @db.Text
  isRead    Boolean          @default(false)
  data      String?          @db.LongText
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "notifications_userId_fkey")
  @@map("notifications")
}

model Admin {
  id             String          @id @default(uuid())
  name           String
  email          String          @unique
  password       String
  role           AdminRole       @default(ADMIN)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  activityLogs   ActivityLog[]
  pageContents   PageContent[]
  reports        Report[]
  supportReplies SupportReply[]
  supportTickets SupportTicket[]
  refreshTokens  RefreshToken[]

  @@map("admins")
}

model ActivityLog {
  id          String   @id @default(uuid())
  adminId     String
  action      String
  entityType  String
  entityId    String?
  description String?  @db.Text
  changes     Json?
  ipAddress   String?
  userAgent   String?  @db.Text
  createdAt   DateTime @default(now())
  admin       Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([createdAt])
  @@map("activity_logs")
}

model SupportTicket {
  id            String              @id @default(uuid())
  userId        String?
  doctorId      String?
  subject       String
  message       String              @db.Text
  status        SupportTicketStatus @default(OPEN)
  priority      SupportPriority     @default(MEDIUM)
  assignedTo    String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  replies       SupportReply[]
  assignedAdmin Admin?              @relation(fields: [assignedTo], references: [id])
  doctor        Doctor?             @relation(fields: [doctorId], references: [id])
  user          User?               @relation(fields: [userId], references: [id])

  @@index([assignedTo], map: "support_tickets_assignedTo_fkey")
  @@index([doctorId], map: "support_tickets_doctorId_fkey")
  @@index([userId], map: "support_tickets_userId_fkey")
  @@map("support_tickets")
}

model SupportReply {
  id         String        @id @default(uuid())
  ticketId   String
  adminId    String?
  userId     String?
  doctorId   String?
  message    String        @db.Text
  isInternal Boolean       @default(false)
  createdAt  DateTime      @default(now())
  admin      Admin?        @relation(fields: [adminId], references: [id])
  doctor     Doctor?       @relation(fields: [doctorId], references: [id])
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user       User?         @relation(fields: [userId], references: [id])

  @@index([adminId], map: "support_replies_adminId_fkey")
  @@index([doctorId], map: "support_replies_doctorId_fkey")
  @@index([ticketId], map: "support_replies_ticketId_fkey")
  @@index([userId], map: "support_replies_userId_fkey")
  @@map("support_replies")
}

model PageContent {
  id                 String   @id @default(uuid())
  pageType           PageType @unique
  titleAr            String
  titleEn            String?
  contentAr          String   @db.Text
  contentEn          String?  @db.Text
  lastUpdatedBy      String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  lastUpdatedByAdmin Admin?   @relation(fields: [lastUpdatedBy], references: [id])

  @@index([lastUpdatedBy], map: "page_contents_lastUpdatedBy_fkey")
  @@map("page_contents")
}

model Report {
  id               String       @id @default(uuid())
  type             ReportType
  name             String
  description      String?      @db.Text
  format           ReportFormat @default(JSON)
  filters          String?      @db.LongText
  generatedBy      String
  filePath         String?
  fileUrl          String?
  status           ReportStatus @default(PENDING)
  startedAt        DateTime     @default(now())
  completedAt      DateTime?
  error            String?      @db.Text
  createdAt        DateTime     @default(now())
  generatedByAdmin Admin        @relation(fields: [generatedBy], references: [id], onDelete: Cascade)

  @@index([generatedBy], map: "reports_generatedBy_fkey")
  @@map("reports")
}

model Coupon {
  id                String       @id @default(uuid())
  code              String       @unique
  type              CouponType
  value             Float
  minAmount         Float?
  maxDiscount       Float?
  usageLimit        Int?
  usageLimitPerUser Int?
  usedCount         Int          @default(0)
  validFrom         DateTime
  validUntil        DateTime
  isActive          Boolean      @default(true)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  userCoupons       UserCoupon[]

  @@map("coupons")
}

model UserCoupon {
  id       String @id @default(uuid())
  couponId String
  userId   String
  coupon   Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([couponId, userId])
  @@index([userId], map: "user_coupons_userId_fkey")
  @@map("user_coupons")
}

model EmailTemplate {
  id        String            @id @default(uuid())
  name      String
  type      EmailTemplateType @unique
  subject   String
  subjectAr String?
  body      String            @db.Text
  bodyAr    String?           @db.Text
  variables String?           @db.LongText
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@map("email_templates")
}

model NotificationTemplate {
  id        String   @id @default(uuid())
  name      String
  type      String
  title     String
  message   String   @db.Text
  variables String?  @db.LongText
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notification_templates")
}

model AppSettings {
  id                        String   @id @default(uuid())
  appName                   String   @default("تواصل")
  appNameEn                 String?  @default("Tawasoul")
  logo                      String?
  logoMobile                String?
  favicon                   String?
  primaryFont               String   @default("Cairo")
  secondaryFont             String?  @default("Tajawal")
  primaryColor              String?  @default("#14b8a6")
  secondaryColor            String?
  maintenanceMode           Boolean  @default(false)
  registrationEnabled       Boolean  @default(true)
  doctorRegistrationEnabled Boolean  @default(true)
  emailNotifications        Boolean  @default(true)
  smsNotifications          Boolean  @default(false)
  maxPostLength             Int?     @default(5000)
  maxFileSize               Int?     @default(10485760)
  allowedFileTypes          String?  @db.LongText
  paymentGateway            String?
  emailService              String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@map("app_settings")
}

model Onboarding {
  id            String   @id @default(uuid())
  title         String
  titleAr       String
  description   String?  @db.Text
  descriptionAr String?  @db.Text
  image         String?
  order         Int      @default(0)
  isActive      Boolean  @default(true)
  platform      String   @default("ALL")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("onboarding")
}

model StaticPage {
  id          String         @id @default(uuid())
  pageType    StaticPageType @unique
  titleAr     String
  titleEn     String?
  contentAr   String         @db.Text
  contentEn   String?        @db.Text
  image       String?
  sliderItems String?        @db.LongText
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@map("static_pages")
}

model HomeSlider {
  id            String   @id @default(uuid())
  titleAr       String
  titleEn       String?
  descriptionAr String?  @db.Text
  descriptionEn String?  @db.Text
  image         String
  buttonText    String?
  buttonLink    String?
  order         Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("home_sliders")
}

model HomeService {
  id            String   @id @default(uuid())
  titleAr       String
  titleEn       String?
  descriptionAr String?  @db.Text
  descriptionEn String?  @db.Text
  image         String
  link          String?
  order         Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("home_services")
}

model HomeArticle {
  id            String   @id @default(uuid())
  titleAr       String
  titleEn       String?
  descriptionAr String?  @db.Text
  descriptionEn String?  @db.Text
  image         String
  link          String?
  order         Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("home_articles")
}

model FAQ {
  id         String   @id @default(uuid())
  questionAr String
  questionEn String?
  answerAr   String   @db.Text
  answerEn   String?  @db.Text
  category   String?
  order      Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("faqs")
}

model OtpCode {
  id        String   @id @default(uuid())
  userId    String?
  phone     String
  code      String
  isUsed    Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([phone, code])
  @@index([expiresAt])
  @@index([userId], map: "otp_codes_userId_fkey")
  @@map("otp_codes")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  
  userId    String?
  doctorId  String?
  adminId   String?
  
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())
  
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  doctor    Doctor?  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  admin     Admin?   @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([expiresAt])
  @@index([userId])
  @@index([doctorId])
  @@index([adminId])
  @@map("refresh_tokens")
}

model Package {
  id             String        @id @default(uuid())
  name           String
  nameAr         String
  description    String?       @db.Text
  descriptionAr  String?       @db.Text
  price          Float
  sessionsCount  Int
  durationMonths Int
  content        String?       @db.LongText
  isActive       Boolean       @default(true)
  isFeatured     Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  payments       Payment[]
  userPackages   UserPackage[]

  @@map("packages")
}

model UserPackage {
  id                String        @id @default(uuid())
  userId            String
  packageId         String
  status            PackageStatus @default(ACTIVE)
  sessionsUsed      Int           @default(0)
  sessionsRemaining Int
  startDate         DateTime      @default(now())
  endDate           DateTime
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  package           Package       @relation(fields: [packageId], references: [id], onDelete: Cascade)
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([packageId], map: "user_packages_packageId_fkey")
  @@index([userId], map: "user_packages_userId_fkey")
  @@map("user_packages")
}

model ProductCategory {
  id        String    @id @default(uuid())
  name      String
  nameAr    String
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]

  @@map("product_categories")
}

model Product {
  id                  String           @id @default(uuid())
  name                String
  nameAr              String
  description         String?          @db.Text
  descriptionAr       String?          @db.Text
  images              String           @db.LongText
  price               Float
  priceBeforeDiscount Float?
  discount            Float?
  rating              Float            @default(0)
  totalRatings        Int              @default(0)
  stock               Int              @default(0)
  isActive            Boolean          @default(true)
  isFeatured          Boolean          @default(false)
  categoryId          String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  cartItems           CartItem[]
  category            ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  orderItems          OrderItem[]
  reviews             ProductReview[]

  @@index([categoryId], map: "products_categoryId_fkey")
  @@map("products")
}

model ProductReview {
  id        String   @id @default(uuid())
  productId String
  userId    String
  rating    Int
  comment   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId])
  @@index([userId], map: "product_reviews_userId_fkey")
  @@map("product_reviews")
}

model CartItem {
  id        String   @id @default(uuid())
  userId    String
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId], map: "cart_items_productId_fkey")
  @@map("cart_items")
}

model Address {
