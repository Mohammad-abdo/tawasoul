generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id               String          @id @default(uuid())
  fullName         String?
  username         String?         @unique
  email            String?         @unique
  phone            String?         @unique
  password         String?
  relationType     RelationType?
  language         String          @default("ar")
  allowPrivateMsg  Boolean         @default(true)
  isAnonymous      Boolean         @default(false)
  avatar           String?
  isActive         Boolean         @default(true)
  isApproved       Boolean         @default(true)
  isPhoneVerified  Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  addresses        Address[]
  bookings         Booking[]
  cartItems        CartItem[]
  children         Child[]
  receivedMessages Message[]       @relation("ReceiverMessages")
  sentMessages     Message[]       @relation("SenderMessages")
  notifications    Notification[]
  orders           Order[]
  otpCodes         OtpCode[]
  productReviews   ProductReview[]
  supportReplies   SupportReply[]
  supportTickets   SupportTicket[]
  coupons          UserCoupon[]
  userPackages     UserPackage[]

  @@map("users")
}

model Article {
  id            String   @id @default(uuid())
  title         String
  content       String   @db.Text
  excerpt       String?  @db.Text
  authorId      String
  views         Int      @default(0)
  likes         Int      @default(0)
  comments      Int      @default(0)
  isRecommended Boolean  @default(false)
  isFeatured    Boolean  @default(false)
  featuredOrder Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  author        Doctor   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId], map: "articles_authorId_fkey")
  @@map("articles")
}

model Doctor {
  id             String            @id @default(uuid())
  name           String
  email          String            @unique
  phone          String
  password       String
  bio            String?           @db.Text
  avatar         String?
  rating         Float             @default(0)
  totalSessions  Int               @default(0)
  totalRatings   Int               @default(0)
  isVerified     Boolean           @default(false)
  isActive       Boolean           @default(true)
  isApproved     Boolean           @default(false)
  approvalNotes  String?           @db.Text
  isFeatured     Boolean           @default(false)
  featuredOrder  Int?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  articles       Article[]
  availability   Availability[]
  bookings       Booking[]
  certificates   Certificate[]
  specialties    DoctorSpecialty[]
  education      Education[]
  experiences    Experience[]
  helpAssessments HelpAssessment[]
  payments       Payment[]
  supportReplies SupportReply[]
  supportTickets SupportTicket[]
  withdrawals    Withdrawal[]

  @@map("doctors")
}

model DoctorSpecialty {
  id        String   @id @default(uuid())
  doctorId  String
  specialty String
  createdAt DateTime @default(now())
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId], map: "doctor_specialties_doctorId_fkey")
  @@map("doctor_specialties")
}

model Experience {
  id        String    @id @default(uuid())
  doctorId  String
  title     String
  workplace String
  startDate DateTime
  endDate   DateTime?
  proofFile String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  doctor    Doctor    @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId], map: "experiences_doctorId_fkey")
  @@map("experiences")
}

model Certificate {
  id              String    @id @default(uuid())
  doctorId        String
  title           String
  issuer          String
  startDate       DateTime
  endDate         DateTime?
  certificateLink String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  doctor          Doctor    @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId], map: "certificates_doctorId_fkey")
  @@map("certificates")
}

model Education {
  id          String    @id @default(uuid())
  doctorId    String
  degree      String
  institution String
  startDate   DateTime
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  doctor      Doctor    @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId], map: "education_doctorId_fkey")
  @@map("education")
}

model Availability {
  id        String   @id @default(uuid())
  doctorId  String
  dayOfWeek Int
  timeSlots String   @db.Text
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, dayOfWeek])
  @@map("availability")
}

model Child {
  id                String                  @id @default(uuid())
  userId            String
  name              String
  gender            Gender?                 @default(MALE)
  age               Int?
  status            ChildStatus?
  ageGroup          ChildAgeGroup?
  behavioralNotes   String?                 @db.Text
  caseDescription   String?                 @db.Text
  caseHistory       String?                 @db.Text
  profileImage      String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  assessmentResults AssessmentResult[]
  activityProgress  ChildActivityProgress[]
  bookings          Booking[]
  helpAssessments   HelpAssessment[]
  user              User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "children_userId_fkey")
  @@map("children")
}

model Booking {
  id                 String          @id @default(uuid())
  userId             String
  doctorId           String
  childId            String?
  category           SessionCategory @default(INDIVIDUAL)
  duration           Int
  price              Float
  status             BookingStatus   @default(PENDING)
  scheduledAt        DateTime
  scheduledMonth     Int?
  scheduledDay       Int?
  scheduledTime      String?
  notes              String?         @db.Text
  completedAt        DateTime?
  cancelledAt        DateTime?
  cancellationReason String?         @db.Text
  paymentId          String?         @unique
  rating             Int?
  review             String?         @db.Text
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  videoLink          String?
  child              Child?          @relation(fields: [childId], references: [id])
  doctor             Doctor          @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  user               User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  payment            Payment?

  @@index([childId], map: "bookings_childId_fkey")
  @@index([doctorId], map: "bookings_doctorId_fkey")
  @@index([userId], map: "bookings_userId_fkey")
  @@map("bookings")
}

model Message {
  id            String      @id @default(uuid())
  senderId      String
  receiverId    String
  content       String?     @db.Text
  messageType   MessageType @default(TEXT)
  imageUrl      String?
  videoUrl      String?
  fileUrl       String?
  fileName      String?
  voiceUrl      String?
  voiceDuration Int?
  isRead        Boolean     @default(false)
  createdAt     DateTime    @default(now())
  receiver      User        @relation("ReceiverMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  sender        User        @relation("SenderMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([receiverId], map: "messages_receiverId_fkey")
  @@index([senderId], map: "messages_senderId_fkey")
  @@map("messages")
}

model Payment {
  id            String        @id @default(uuid())
  bookingId     String        @unique
  doctorId      String
  amount        Float
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  transactionId String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  booking       Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  doctor        Doctor        @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId], map: "payments_doctorId_fkey")
  @@map("payments")
}

model Withdrawal {
  id             String           @id @default(uuid())
  doctorId       String
  amount         Float
  method         WithdrawalMethod
  accountDetails String           @db.Text
  status         WithdrawalStatus @default(PENDING)
  processedAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  doctor         Doctor           @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId], map: "withdrawals_doctorId_fkey")
  @@map("withdrawals")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String           @db.Text
  isRead    Boolean          @default(false)
  data      String?          @db.LongText
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "notifications_userId_fkey")
  @@map("notifications")
}

model Admin {
  id             String          @id @default(uuid())
  name           String
  email          String          @unique
  password       String
  role           AdminRole       @default(ADMIN)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  pageContents   PageContent[]
  reports        Report[]
  supportReplies SupportReply[]
  supportTickets SupportTicket[]

  @@map("admins")
}

model SupportTicket {
  id            String              @id @default(uuid())
  userId        String?
  doctorId      String?
  subject       String
  message       String              @db.Text
  status        SupportTicketStatus @default(OPEN)
  priority      SupportPriority     @default(MEDIUM)
  assignedTo    String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  replies       SupportReply[]
  assignedAdmin Admin?              @relation(fields: [assignedTo], references: [id])
  doctor        Doctor?             @relation(fields: [doctorId], references: [id])
  user          User?               @relation(fields: [userId], references: [id])

  @@index([assignedTo], map: "support_tickets_assignedTo_fkey")
  @@index([doctorId], map: "support_tickets_doctorId_fkey")
  @@index([userId], map: "support_tickets_userId_fkey")
  @@map("support_tickets")
}

model SupportReply {
  id         String        @id @default(uuid())
  ticketId   String
  adminId    String?
  userId     String?
  doctorId   String?
  message    String        @db.Text
  isInternal Boolean       @default(false)
  createdAt  DateTime      @default(now())
  admin      Admin?        @relation(fields: [adminId], references: [id])
  doctor     Doctor?       @relation(fields: [doctorId], references: [id])
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user       User?         @relation(fields: [userId], references: [id])

  @@index([adminId], map: "support_replies_adminId_fkey")
  @@index([doctorId], map: "support_replies_doctorId_fkey")
  @@index([ticketId], map: "support_replies_ticketId_fkey")
  @@index([userId], map: "support_replies_userId_fkey")
  @@map("support_replies")
}

model PageContent {
  id                 String   @id @default(uuid())
  pageType           PageType @unique
  titleAr            String
  titleEn            String?
  contentAr          String   @db.Text
  contentEn          String?  @db.Text
  lastUpdatedBy      String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  lastUpdatedByAdmin Admin?   @relation(fields: [lastUpdatedBy], references: [id])

  @@index([lastUpdatedBy], map: "page_contents_lastUpdatedBy_fkey")
  @@map("page_contents")
}

model Report {
  id               String       @id @default(uuid())
  type             ReportType
  name             String
  description      String?      @db.Text
  format           ReportFormat @default(JSON)
  filters          String?      @db.LongText
  generatedBy      String
  filePath         String?
  fileUrl          String?
  status           ReportStatus @default(PENDING)
  startedAt        DateTime     @default(now())
  completedAt      DateTime?
  error            String?      @db.Text
  createdAt        DateTime     @default(now())
  generatedByAdmin Admin        @relation(fields: [generatedBy], references: [id], onDelete: Cascade)

  @@index([generatedBy], map: "reports_generatedBy_fkey")
  @@map("reports")
}

model Coupon {
  id                String             @id @default(uuid())
  code              String             @unique
  type              CouponType
  value             Float
  minAmount         Float?
  maxDiscount       Float?
  usageLimit        Int?
  usageLimitPerUser Int?
  usedCount         Int                @default(0)
  validFrom         DateTime
  validUntil        DateTime
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  userCoupons       UserCoupon[]

  @@map("coupons")
}

model UserCoupon {
  id       String @id @default(uuid())
  couponId String
  userId   String
  coupon   Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([couponId, userId])
  @@index([userId], map: "user_coupons_userId_fkey")
  @@map("user_coupons")
}

model EmailTemplate {
  id        String            @id @default(uuid())
  name      String
  type      EmailTemplateType @unique
  subject   String
  subjectAr String?
  body      String            @db.Text
  bodyAr    String?           @db.Text
  variables String?           @db.LongText
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@map("email_templates")
}

model NotificationTemplate {
  id        String   @id @default(uuid())
  name      String
  type      String
  title     String
  message   String   @db.Text
  variables String?  @db.LongText
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notification_templates")
}

model AppSettings {
  id                        String   @id @default(uuid())
  appName                   String   @default("تواصل")
  appNameEn                 String?  @default("Tawasoul")
  logo                      String?
  logoMobile                String?
  favicon                   String?
  primaryFont               String   @default("Cairo")
  secondaryFont             String?  @default("Tajawal")
  primaryColor              String?  @default("#14b8a6")
  secondaryColor            String?
  maintenanceMode           Boolean  @default(false)
  registrationEnabled       Boolean  @default(true)
  doctorRegistrationEnabled Boolean  @default(true)
  emailNotifications        Boolean  @default(true)
  smsNotifications          Boolean  @default(false)
  maxPostLength             Int?     @default(5000)
  maxFileSize               Int?     @default(10485760)
  allowedFileTypes          String?  @db.LongText
  paymentGateway            String?
  emailService              String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@map("app_settings")
}

model Onboarding {
  id            String   @id @default(uuid())
  title         String
  titleAr       String
  description   String?  @db.Text
  descriptionAr String?  @db.Text
  image         String?
  order         Int      @default(0)
  isActive      Boolean  @default(true)
  platform      String   @default("ALL")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("onboarding")
}

model StaticPage {
  id          String         @id @default(uuid())
  pageType    StaticPageType @unique
  titleAr     String
  titleEn     String?
  contentAr   String         @db.Text
  contentEn   String?        @db.Text
  image       String?
  sliderItems String?        @db.LongText
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@map("static_pages")
}

model HomeSlider {
  id            String   @id @default(uuid())
  titleAr       String
  titleEn       String?
  descriptionAr String?  @db.Text
  descriptionEn String?  @db.Text
  image         String
  buttonText    String?
  buttonLink    String?
  order         Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("home_sliders")
}

model HomeService {
  id            String   @id @default(uuid())
  titleAr       String
  titleEn       String?
  descriptionAr String?  @db.Text
  descriptionEn String?  @db.Text
  image         String
  link          String?
  order         Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("home_services")
}

model HomeArticle {
  id            String   @id @default(uuid())
  titleAr       String
  titleEn       String?
  descriptionAr String?  @db.Text
  descriptionEn String?  @db.Text
  image         String
  link          String?
  order         Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("home_articles")
}

model FAQ {
  id         String   @id @default(uuid())
  questionAr String
  questionEn String?
  answerAr   String   @db.Text
  answerEn   String?  @db.Text
  category   String?
  order      Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("faqs")
}

model OtpCode {
  id        String   @id @default(uuid())
  userId    String?
  phone     String
  code      String
  isUsed    Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([phone, code])
  @@index([expiresAt])
  @@index([userId], map: "otp_codes_userId_fkey")
  @@map("otp_codes")
}

model Package {
  id             String        @id @default(uuid())
  name           String
  nameAr         String
  description    String?       @db.Text
  descriptionAr  String?       @db.Text
  price          Float
  sessionsCount  Int
  durationMonths Int
  content        String?       @db.LongText
  isActive       Boolean       @default(true)
  isFeatured     Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  userPackages   UserPackage[]

  @@map("packages")
}

model UserPackage {
  id                String        @id @default(uuid())
  userId            String
  packageId         String
  status            PackageStatus @default(ACTIVE)
  sessionsUsed      Int           @default(0)
  sessionsRemaining Int
  startDate         DateTime      @default(now())
  endDate           DateTime
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  package           Package       @relation(fields: [packageId], references: [id], onDelete: Cascade)
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([packageId], map: "user_packages_packageId_fkey")
  @@index([userId], map: "user_packages_userId_fkey")
  @@map("user_packages")
}

model ProductCategory {
  id        String    @id @default(uuid())
  name      String
  nameAr    String
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]

  @@map("product_categories")
}

model Product {
  id                  String           @id @default(uuid())
  name                String
  nameAr              String
  description         String?          @db.Text
  descriptionAr       String?          @db.Text
  images              String           @db.LongText
  price               Float
  priceBeforeDiscount Float?
  discount            Float?
  rating              Float            @default(0)
  totalRatings        Int              @default(0)
  stock               Int              @default(0)
  isActive            Boolean          @default(true)
  isFeatured          Boolean          @default(false)
  categoryId          String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  cartItems           CartItem[]
  category            ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  orderItems          OrderItem[]
  reviews             ProductReview[]

  @@index([categoryId], map: "products_categoryId_fkey")
  @@map("products")
}

model ProductReview {
  id        String   @id @default(uuid())
  productId String
  userId    String
  rating    Int
  comment   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId])
  @@index([userId], map: "product_reviews_userId_fkey")
  @@map("product_reviews")
}

model CartItem {
  id        String   @id @default(uuid())
  userId    String
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId], map: "cart_items_productId_fkey")
  @@map("cart_items")
}

model Address {
  id          String   @id @default(uuid())
  userId      String
  label       String
  fullAddress String   @db.Text
  latitude    Float?
  longitude   Float?
  city        String?
  country     String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders      Order[]

  @@index([userId], map: "addresses_userId_fkey")
  @@map("addresses")
}

model Order {
  id            String         @id @default(uuid())
  userId        String
  addressId     String?
  orderNumber   String         @unique
  subtotal      Float
  total         Float
  status        OrderStatus    @default(PENDING)
  paymentMethod PaymentMethod?
  paymentStatus PaymentStatus  @default(PENDING)
  transactionId String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  items         OrderItem[]
  address       Address?       @relation(fields: [addressId], references: [id])
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([addressId], map: "orders_addressId_fkey")
  @@index([userId], map: "orders_userId_fkey")
  @@map("orders")
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([orderId], map: "order_items_orderId_fkey")
  @@index([productId], map: "order_items_productId_fkey")
  @@map("order_items")
}

model Test {
  id          String              @id @default(uuid())
  title       String
  titleAr     String? // عنوان بالعربية (مثل: تمييز الأصوات، النطق والتكرار)
  type        TestModality        @default(AUDITORY) // Keep for backward compatibility/sub-type
  testType    TestType            @default(CARS) // نوع الاختبار داخل الفئة
  description String?             @db.Text
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  assessmentResults AssessmentResult[]
  questions   Question[]
  qCarsQuestions Q_CARS[]
  qAnalogyQuestions Q_Analogy[]
  qVisualMemoryBatches Q_VisualMemory_Batch[]
  qAuditoryMemoryQuestions Q_AuditoryMemory[]
  qSequenceOrderQuestions  Q_SequenceOrder[]
  @@map("tests")
}

model Question {
  id                String             @id @default(uuid())
  testId            String
  orderIndex        Int                @default(0) // ترتيب السؤال داخل الاختبار (للتسلسل والترتيب)
  audioAssetPath    String? // تسجيل التعليمات الصوتية
  imageAssetPath    String?
  choices           Json? // الاختيارات حسب نوع الاختبار [{ text, imagePath?, audioPath?, isCorrect }]
  scoringGuide      String?            @db.Text // نقاط التقييم / دليل الدرجة
  maxScore          Int?               @default(10) // أعلى درجة لهذا السؤال
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  assessmentResults AssessmentResult[]
  test              Test               @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@index([testId], map: "questions_testId_fkey")
  @@map("questions")
}

model AssessmentResult {
  id                     String                    @id @default(uuid())
  childId                String
  testId                 String?
  questionId             String?
  scoreGiven             Int?
  totalScore             Int?
  maxScore               Int?
  sessionId              String?
  timestamp              DateTime                  @default(now())
  child                  Child                     @relation(fields: [childId], references: [id], onDelete: Cascade)
  test                   Test?                     @relation(fields: [testId], references: [id], onDelete: Cascade)
  question               Question?                 @relation(fields: [questionId], references: [id], onDelete: SetNull)
  helpAssessment         HelpAssessment?
  qCarsAnswers           Q_CARS_Answer[]
  qAnalogyAnswers        Q_Analogy_Answer[]
  qVisualMemoryAnswers   Q_VisualMemory_Answer[]
  qAuditoryMemoryAnswers Q_AuditoryMemory_Answer[]
  qSequenceOrderAnswers    Q_SequenceOrder_Answer[]
  
  @@index([childId], map: "assessment_results_childId_fkey")
  @@index([testId], map: "assessment_results_testId_fkey")
  @@index([questionId], map: "assessment_results_questionId_fkey")
  @@index([sessionId], map: "assessment_results_sessionId_idx")
  @@map("assessment_results")
}

model HelpSkill {
  id          String           @id @default(uuid())
  domain      HelpDomain
  skillNumber String
  description String
  ageRange    String
  evaluations HelpEvaluation[]

  @@map("help_skills")
}

model HelpAssessment {
  id                 String            @id @default(uuid())
  childId            String
  doctorId           String
  assessmentResultId String?           @unique
  sessionId          String
  developmentalAge   String
  createdAt          DateTime          @default(now())
  child              Child             @relation(fields: [childId], references: [id], onDelete: Cascade)
  doctor             Doctor            @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  assessmentResult   AssessmentResult? @relation(fields: [assessmentResultId], references: [id], onDelete: SetNull)
  evaluations        HelpEvaluation[]

  @@index([childId], map: "help_assessments_childId_fkey")
  @@index([doctorId], map: "help_assessments_doctorId_fkey")
  @@index([sessionId], map: "help_assessments_sessionId_idx")
  @@map("help_assessments")
}

model HelpEvaluation {
  id           String         @id @default(uuid())
  assessmentId String
  skillId      String
  score        HelpScore
  doctorNotes  String?        @db.Text
  assessment   HelpAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  skill        HelpSkill      @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, skillId])
  @@index([assessmentId], map: "help_evaluations_assessmentId_fkey")
  @@index([skillId], map: "help_evaluations_skillId_fkey")
  @@map("help_evaluations")
}

model ActivityCategory {
  id          String       @id @default(uuid())
  name        String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  skillGroups SkillGroup[]

  @@map("activity_categories")
}

model SkillGroup {
  id         String           @id @default(uuid())
  categoryId String
  name       String
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  category   ActivityCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  activities Activity[]

  @@index([categoryId])
  @@map("skill_groups")
}

model Activity {
  id              String                  @id @default(uuid())
  skillGroupId    String
  type            ActivityType
  levelOrder      Int
  correctImageId  String?                 @unique
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  skillGroup      SkillGroup              @relation(fields: [skillGroupId], references: [id], onDelete: Cascade)
  images          ActivityImage[]
  audios          ActivityAudio[]
  matchPairs      ActivityMatchPair[]
  sequenceItems   ActivitySequenceItem[]
  progressRecords ChildActivityProgress[]
  correctImage    ActivityImage?          @relation("CorrectImage", fields: [correctImageId], references: [id])

  @@unique([skillGroupId, levelOrder])
  @@index([skillGroupId])
  @@map("activities")
}

model ActivityImage {
  id            String                 @id @default(uuid())
  activityId    String
  assetPath     String
  sortOrder     Int                    @default(0)
  createdAt     DateTime               @default(now())
  activity      Activity               @relation(fields: [activityId], references: [id], onDelete: Cascade)
  correctFor    Activity?              @relation("CorrectImage")
  matchPairs    ActivityMatchPair[]
  sequenceItems ActivitySequenceItem[]

  @@index([activityId])
  @@map("activity_images")
}

model ActivityAudio {
  id         String              @id @default(uuid())
  activityId String
  assetPath  String
  sortOrder  Int                 @default(0)
  createdAt  DateTime            @default(now())
  activity   Activity            @relation(fields: [activityId], references: [id], onDelete: Cascade)
  matchPairs ActivityMatchPair[]

  @@index([activityId])
  @@map("activity_audios")
}

model ActivityMatchPair {
  id         String        @id @default(uuid())
  activityId String
  imageId    String
  audioId    String
  activity   Activity      @relation(fields: [activityId], references: [id], onDelete: Cascade)
  image      ActivityImage @relation(fields: [imageId], references: [id], onDelete: Cascade)
  audio      ActivityAudio @relation(fields: [audioId], references: [id], onDelete: Cascade)

  @@unique([activityId, imageId])
  @@unique([activityId, audioId])
  @@index([activityId])
  @@map("activity_match_pairs")
}

model ActivitySequenceItem {
  id         String        @id @default(uuid())
  activityId String
  imageId    String
  position   Int
  activity   Activity      @relation(fields: [activityId], references: [id], onDelete: Cascade)
  image      ActivityImage @relation(fields: [imageId], references: [id], onDelete: Cascade)

  @@unique([activityId, position])
  @@unique([activityId, imageId])
  @@index([activityId])
  @@map("activity_sequence_items")
}

model ChildActivityProgress {
  id          String    @id @default(uuid())
  childId     String
  activityId  String
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  child       Child     @relation(fields: [childId], references: [id], onDelete: Cascade)
  activity    Activity  @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([childId, activityId])
  @@index([childId])
  @@index([activityId])
  @@map("child_activity_progress")
}

model Q_CARS {
  id           String          @id @default(cuid())
  testId       String
  order        Int
  questionText Json
  choices      Json
  test         Test            @relation(fields: [testId], references: [id], onDelete: Cascade)
  answers      Q_CARS_Answer[]

  @@index([testId], map: "q_cars_testId_fkey")
}

model Q_CARS_Answer {
  id           String            @id @default(cuid())
  resultId     String
  questionId   String
  chosenIndex  Int
  score        Int
  result       AssessmentResult  @relation(fields: [resultId], references: [id], onDelete: Cascade)
  question     Q_CARS            @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([resultId, questionId])
  @@index([resultId], map: "q_cars_answers_resultId_fkey")
  @@index([questionId], map: "q_cars_answers_questionId_fkey")
}

model Q_Analogy {
  id               String             @id @default(cuid())
  testId           String
  order            Int
  questionImageUrl String
  choices          Json
  correctIndex     Int
  test             Test               @relation(fields: [testId], references: [id], onDelete: Cascade)
  answers          Q_Analogy_Answer[]

  @@index([testId], map: "q_analogy_testId_fkey")
}

model Q_Analogy_Answer {
  id           String             @id @default(cuid())
  resultId     String
  questionId   String
  chosenIndex  Int
  score        Int
  result       AssessmentResult   @relation(fields: [resultId], references: [id], onDelete: Cascade)
  question     Q_Analogy          @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([resultId, questionId])
  @@index([resultId], map: "q_analogy_answers_resultId_fkey")
  @@index([questionId], map: "q_analogy_answers_questionId_fkey")
}

model Q_VisualMemory_Batch {
  id             String            @id @default(cuid())
  testId         String
  order          Int
  imageUrl       String
  displaySeconds Int
  test           Test              @relation(fields: [testId], references: [id], onDelete: Cascade)
  questions      Q_VisualMemory[]

  @@index([testId], map: "q_visual_memory_batches_testId_fkey")
}

model Q_VisualMemory {
  id           String                 @id @default(cuid())
  batchId      String
  order        Int
  questionText Json
  questionType VisualMemoryQType
  correctBool  Boolean?
  choices      Json?
  correctIndex Int?
  batch        Q_VisualMemory_Batch   @relation(fields: [batchId], references: [id], onDelete: Cascade)
  answers      Q_VisualMemory_Answer[]

  @@index([batchId], map: "q_visual_memory_batchId_fkey")
}

model Q_VisualMemory_Answer {
  id          String                  @id @default(cuid())
  resultId    String
  questionId  String
  answerBool  Boolean?
  chosenIndex Int?
  score       Int
  result      AssessmentResult        @relation(fields: [resultId], references: [id], onDelete: Cascade)
  question    Q_VisualMemory          @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([resultId, questionId])
  @@index([resultId], map: "q_visual_memory_answers_resultId_fkey")
  @@index([questionId], map: "q_visual_memory_answers_questionId_fkey")
}

model Q_AuditoryMemory {
  id           String                    @id @default(cuid())
  testId       String
  order        Int
  audioClipUrl String
  questionText Json
  modelAnswer  Json
  test         Test                      @relation(fields: [testId], references: [id], onDelete: Cascade)
  answers      Q_AuditoryMemory_Answer[]

  @@index([testId], map: "q_auditory_memory_testId_fkey")
}

model Q_AuditoryMemory_Answer {
  id            String                    @id @default(cuid())
  resultId      String
  questionId    String
  recalledItems Json
  itemScores    Json
  score         Int
  result        AssessmentResult          @relation(fields: [resultId], references: [id], onDelete: Cascade)
  question      Q_AuditoryMemory          @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([resultId, questionId])
  @@index([resultId], map: "q_auditory_memory_answers_resultId_fkey")
  @@index([questionId], map: "q_auditory_memory_answers_questionId_fkey")
}

enum VisualMemoryQType {
  YES_NO
  MCQ
}

model Q_SequenceOrder {
  id          String                    @id @default(cuid())
  testId      String
  order       Int
  images      Q_SequenceOrder_Image[]
  test        Test                      @relation(fields: [testId], references: [id], onDelete: Cascade)
  answers     Q_SequenceOrder_Answer[]

  @@unique([testId, order])
  @@index([testId], map: "q_sequence_order_testId_fkey")
  @@map("q_sequence_order")
}

model Q_SequenceOrder_Image {
  id          String           @id @default(cuid())
  questionId  String
  assetPath   String
  position    Int              // correct position: 1-based, 1 to 3 or 4
  question    Q_SequenceOrder  @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, position])
  @@index([questionId], map: "q_sequence_order_image_questionId_fkey")
  @@map("q_sequence_order_images")
}

model Q_SequenceOrder_Answer {
  id              String                       @id @default(cuid())
  resultId        String
  questionId      String
  submittedOrder  Json                         // array of { imageId, submittedPosition }
  itemScores      Json                         // array of { imageId, correctPosition, submittedPosition, score: 0|1 }
  score           Int                          // sum of itemScores — partial credit per position
  result          AssessmentResult             @relation(fields: [resultId], references: [id], onDelete: Cascade)
  question        Q_SequenceOrder              @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([resultId, questionId])
  @@index([resultId], map: "q_sequence_order_answer_resultId_fkey")
  @@index([questionId], map: "q_sequence_order_answer_questionId_fkey")
  @@map("q_sequence_order_answers")
}

